# Local environment configuration for NocoDB tests
# Copy this to .env when running tests locally

# Local NocoDB instance
NOCODB_URL=http://localhost:8080/
ENVIRONMENT=local

# Admin credentials (should match your local docker-compose.yml)
NC_ADMIN_EMAIL=admin@example.com
NC_ADMIN_PASSWORD=12341234

# Table IDs (these should match your local database)
EMPLOYEES_TABLE_ID=m3jxshm3jce0b2v

# API Token (you may need to generate this from your local NocoDB instance)
# API_TOKEN=your_local_api_token_here

# Department and Role IDs (if using department/role tests)
DEPT_IT_ID=1
DEPT_HR_ID=2
DEPT_FINANCE_ID=3
ROLE_MANAGER_ID=1
ROLE_DEVELOPER_ID=2
ROLE_HR_SPECIALIST_ID=3
